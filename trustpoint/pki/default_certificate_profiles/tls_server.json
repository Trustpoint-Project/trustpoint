{
    "type": "cert_profile",
    "display_name": "TLS Server",
    "credential_type": "application",
    "subj": {
        "allow":"*",
        "cn": {
            "default": "tls_server.local"
        }
    },
    "reject_mods": false,
    "ext": {
        "basic_constraints": {
            "ca": false
        },
        "subject_alternative_name": {
            "dns_names": {
                "default": ["localhost"]
            },
            "ip_addresses": {
                "default": ["127.0.0.1", "::1"]
            },
            "critical": true
        },
        "key_usage": {
            "digital_signature": true,
            "key_encipherment": true,
            "key_agreement": true
        },
        "extended_key_usage": {
            "usages": {
                "value": [
                    "server_auth"
                ]
            }
        }
    },
    "validity": {
        "days": 10
    }
}