{
    "type": "cert_profile",
    "display_name": "TLS Client",
    "credential_type": "application",
    "subj": {
        "allow":"*",
        "cn": {
            "default": "Example TLS Client"
        }
    },
    "reject_mods": false,
    "ext": {
        "basic_constraints": {
            "ca": false
        },
        "subject_alternative_name": {
            "allow": "*"
        },
        "key_usage": {
            "digital_signature": true,
            "key_encipherment": true,
            "key_agreement": true
        },
        "extended_key_usage": {
            "usages": {
                "value": [
                    "client_auth"
                ]
            }
        }
    },
    "validity": {
        "days": 10
    }
}