{
  "type": "agent_profile",
  "name": "Domain Credential Update",
  "profile": {
    "metadata": {
      "agent_type": "1-to-1",
      "version": "1.0",
      "description": "Renewal policy for a 1-to-1 agent's own domain credential (LDevID)."
    },
    "device": {
      "vendor": "Generic",
      "device_family": "Device",
      "firmware": "1.0"
    },
    "local_storage": {
      "os_path": "{{ os_path }}",
      "certificate_path": "{{ os_path }}/{{ common_name }}-certificate.pem",
      "certificate_chain_path": "{{ os_path }}/{{ common_name }}-full-chain.pem",
      "csr_path": "{{ os_path }}/{{ common_name }}-csr.pem",
      "private_key_path": "{{ os_path }}/{{ common_name }}-key.pem",
      "crl_path": "{{ os_path }}/{{ common_name }}-crl.pem"
    },
    "certificate_request": {
      "certificate_profile": "domain_credential",
      "url": "{{ endpoint }}",
      "path": "{{ path }}",
      "subject": "{{ subject }}",
      "subject_alt_name": "{{ subject_alt_name }}",
      "public_key_algorithm_oid": "{{ public_key_algorithm_oid }}",
      "key_parameter": "{{ key_parameter }}"
    }
  }
}