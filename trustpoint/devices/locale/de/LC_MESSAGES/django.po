msgstr "Unbekanntes Dateiformat."

#: trustpoint/devices/views.py:2549
msgid "The provided password is not valid."
msgstr "Das angegebene Passwort ist ungültig."

#: trustpoint/devices/views.py:2622
msgid "Credential is already expired. Cannot revoke expired certificates."
msgstr ""
"Credential ist bereits abgelaufen. Abgelaufene Zertifikate können nicht "
"widerrufen werden."

#: trustpoint/devices/views.py:2626
msgid ""
"Certificate is already revoked. Cannot revoke a revoked certificate again."
msgstr ""
"Das Zertifikat wurde bereits widerrufen. Ein widerrufenes Zertifikat kann "
"nicht erneut widerrufen werden."

#: trustpoint/devices/views.py:2630 trustpoint/devices/views.py:2786
#, python-format
msgid "Successfully revoked one active credential."
msgid_plural "Successfully revoked %(count)d active credentials."
msgstr[0] "Ein aktives Credential wurde erfolgreich widerrufen."
msgstr[1] "%(count)d aktive Credential(s) wurden erfolgreich widerrufen."

#: trustpoint/devices/views.py:2634
msgid "Failed to revoke certificate. See logs for more information."
msgstr ""
"Das Zertifikat konnte nicht widerrufen werden. Weitere Informationen finden "
"Sie in den Protokollen."

#: trustpoint/devices/views.py:2709
msgid "Please select the devices you would like to revoke."
msgstr "Bitte wählen Sie die Geräte aus, die Sie widerrufen möchten."

#: trustpoint/devices/views.py:2745 trustpoint/devices/views.py:2903
msgid ""
"This operation will revoke ALL certificates associated with the selected "
"devices."
msgstr ""
"Dieser Vorgang widerruft ALLE Zertifikate, die mit den ausgewählten Geräten "
"verbunden sind."

#: trustpoint/devices/views.py:2793
msgid "No credentials were revoked."
msgstr "Es wurden keine Zugangsdaten widerrufen."

#: trustpoint/devices/views.py:2867
msgid "Please select the devices you would like to delete."
msgstr "Bitte wählen Sie die Geräte aus, die Sie löschen möchten."

#: trustpoint/devices/views.py:2928
#, python-brace-format
msgid ""
"Successfully deleted {count} devices. All corresponding certificates have "
"been revoked."
msgstr ""
"{count} Geräte wurden erfolgreich gelöscht. Alle entsprechenden Zertifikate "
"wurden widerrufen."

#: trustpoint/devices/views.py:2936
msgid "Failed to delete DeviceModel records. See logs for more information."
msgstr ""
"Löschen der Gerätemodell-Einträge fehlgeschlagen. Weitere Informationen "
"finden Sie in den Protokollen."
