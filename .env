# Development defaults used by docker compose and tp_wizard.sh.
# Override these values locally for production-like deployments.

# PostgreSQL connection used by the Trustpoint containers.
POSTGRES_DB=trustpoint_db
DATABASE_USER=admin
DATABASE_PASSWORD=testing321
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Hostnames / IP addresses at which Trustpoint is reachable, comma-separated.
# Do not include the protocol. Include a port only when it differs from 80/443.
TP_URLS=trustpoint.local

# Optional mail settings. Leave EMAIL_HOST empty to use Django's console backend.
DEFAULT_FROM_EMAIL=no-reply@trustpoint.de
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=
EMAIL_USE_SSL=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=10
